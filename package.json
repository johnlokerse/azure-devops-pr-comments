{
  "name": "azure-devops-pr-comments",
  "displayName": "Azure DevOps PR Comments",
  "description": "Show Azure DevOps pull request comments inline in VS Code",
  "version": "0.7.0",
  "publisher": "JohnLokerse",
  "repository": {
    "type": "git",
    "url": "https://github.com/johnlokerse/azure-devops-pr-comments.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "icon": "images/icon.png",
  "categories": [
    "Other"
  ],
  "keywords": [
    "azure devops",
    "pull request",
    "code review",
    "comments",
    "pr"
  ],
  "activationEvents": [
    "workspaceContains:.git"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "azurePrComments.signIn",
        "title": "Sign In to Azure DevOps",
        "category": "Azure DevOps PR Comments"
      },
      {
        "command": "azurePrComments.signOut",
        "title": "Sign Out of Azure DevOps",
        "category": "Azure DevOps PR Comments"
      },
      {
        "command": "azurePrComments.refresh",
        "title": "Refresh PR Comments",
        "category": "Azure DevOps PR Comments",
        "icon": "$(refresh)"
      },
      {
        "command": "azurePrComments.openInAzureDevOps",
        "title": "Open in Azure DevOps",
        "category": "Azure DevOps PR Comments",
        "icon": "$(link-external)"
      },
      {
        "command": "azurePrComments.replyToThread",
        "title": "Reply",
        "category": "Azure DevOps PR Comments",
        "enablement": "!commentIsEmpty"
      },
      {
        "command": "azurePrComments.diagnose",
        "title": "Show Diagnostics",
        "category": "Azure DevOps PR Comments"
      },
      {
        "command": "azurePrComments.resolveThread",
        "title": "Resolve Thread",
        "category": "Azure DevOps PR Comments"
      },
      {
        "command": "azurePrComments.reopenThread",
        "title": "Reopen Thread",
        "category": "Azure DevOps PR Comments"
      },
      {
        "command": "azurePrComments.setThreadStatus",
        "title": "Set Thread Status",
        "category": "Azure DevOps PR Comments",
        "icon": "$(chevron-down)"
      },
      {
        "command": "azurePrComments.setStatusActive",
        "title": "Active",
        "category": "Azure DevOps PR Comments"
      },
      {
        "command": "azurePrComments.setStatusPending",
        "title": "Pending",
        "category": "Azure DevOps PR Comments"
      },
      {
        "command": "azurePrComments.setStatusResolved",
        "title": "Resolved",
        "category": "Azure DevOps PR Comments"
      },
      {
        "command": "azurePrComments.setStatusWontFix",
        "title": "Won't Fix",
        "category": "Azure DevOps PR Comments"
      },
      {
        "command": "azurePrComments.setStatusClosed",
        "title": "Closed",
        "category": "Azure DevOps PR Comments"
      },
      {
        "command": "azurePrComments.applySuggestion",
        "title": "Apply Suggestion",
        "category": "Azure DevOps PR Comments"
      }
    ],
    "submenus": [
      {
        "id": "azurePrComments.statusMenu",
        "label": "Mark as",
        "icon": "$(list-flat)"
      }
    ],
    "menus": {
      "commandPalette": [
        { "command": "azurePrComments.replyToThread", "when": "false" },
        { "command": "azurePrComments.applySuggestion", "when": "false" },
        { "command": "azurePrComments.resolveThread", "when": "false" },
        { "command": "azurePrComments.reopenThread", "when": "false" },
        { "command": "azurePrComments.setThreadStatus", "when": "false" },
        { "command": "azurePrComments.setStatusActive", "when": "false" },
        { "command": "azurePrComments.setStatusPending", "when": "false" },
        { "command": "azurePrComments.setStatusResolved", "when": "false" },
        { "command": "azurePrComments.setStatusWontFix", "when": "false" },
        { "command": "azurePrComments.setStatusClosed", "when": "false" }
      ],
      "comments/commentThread/context": [
        {
          "command": "azurePrComments.replyToThread",
          "group": "inline",
          "when": "commentController == azurePrComments && !commentThreadIsEmpty"
        }
      ],
      "comments/commentThread/title": [
        {
          "submenu": "azurePrComments.statusMenu",
          "group": "inline",
          "when": "commentController == azurePrComments"
        }
      ],
      "azurePrComments.statusMenu": [
        { "command": "azurePrComments.setStatusActive",   "group": "1_unresolved@1", "when": "commentController == azurePrComments" },
        { "command": "azurePrComments.setStatusPending",  "group": "1_unresolved@2", "when": "commentController == azurePrComments" },
        { "command": "azurePrComments.setStatusResolved", "group": "2_resolved@1",   "when": "commentController == azurePrComments" },
        { "command": "azurePrComments.setStatusWontFix",  "group": "2_resolved@2",   "when": "commentController == azurePrComments" },
        { "command": "azurePrComments.setStatusClosed",   "group": "2_resolved@3",   "when": "commentController == azurePrComments" }
      ]
    },
    "configuration": {
      "title": "Azure DevOps PR Comments",
      "properties": {
        "azureDevOpsPrComments.organizationUrl": {
          "type": "string",
          "default": "",
          "description": "Override auto-detected Azure DevOps organization URL (e.g. https://dev.azure.com/myorg)"
        },
        "azureDevOpsPrComments.project": {
          "type": "string",
          "default": "",
          "description": "Override auto-detected Azure DevOps project name"
        },
        "azureDevOpsPrComments.showResolvedThreads": {
          "type": "boolean",
          "default": false,
          "description": "Show resolved comment threads"
        },
        "azureDevOpsPrComments.autoRefreshInterval": {
          "type": "number",
          "default": 5,
          "minimum": 0,
          "description": "Interval in minutes to automatically refresh PR comments. Set to 0 to disable."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build:prod",
    "build": "node esbuild.js",
    "build:prod": "node esbuild.js --production",
    "watch": "node esbuild.js --watch",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^20.x",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "esbuild": "^0.20.0",
    "eslint": "^8.56.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "azure-devops-node-api": "^14.0.0"
  }
}
